.import-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 72rpx;
}

.import-hero,
.import-form-card,
.result-card {
  padding: 32rpx 28rpx;
}

.import-hero {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.import-hero-title {
  font-size: 46rpx;
  line-height: 1.26;
  font-weight: 800;
  color: var(--text-primary);
}

.import-hero-text {
  font-size: 27rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.section-gap {
  margin-top: 30rpx;
}

.form-input {
  margin-top: 18rpx;
  width: 100%;
  min-height: 92rpx;
  border-radius: 24rpx;
  background: #f8fcf5;
  border: 2rpx solid #dbeed1;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.library-switch {
  margin-top: 18rpx;
  display: flex;
  gap: 18rpx;
}

.library-pill {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 999rpx;
  background: #eef5ea;
  color: var(--text-secondary);
  font-size: 28rpx;
  font-weight: 700;
}

.library-pill-active {
  background: linear-gradient(180deg, #76dd35 0%, var(--brand-green) 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 24rpx rgba(88, 204, 2, 0.2);
}

.format-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #fbfff8 0%, #f3faee 100%);
  border: 2rpx solid #dcefd0;
}

.format-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.format-title {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.format-text {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.raw-textarea {
  margin-top: 18rpx;
  width: 100%;
  min-height: 520rpx;
  border-radius: 28rpx;
  background: #fbfef9;
  border: 2rpx solid #dcefd0;
  padding: 24rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: var(--text-primary);
}

.toolbar-row {
  margin-top: 18rpx;
  display: flex;
  gap: 16rpx;
}

.toolbar-btn {
  flex: 1;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 700;
  padding: 20rpx 0;
}

.toolbar-secondary {
  background: rgba(28, 140, 255, 0.12);
  color: var(--brand-blue-dark);
}

.toolbar-ghost {
  background: rgba(23, 48, 11, 0.06);
  color: var(--text-secondary);
}

.import-submit {
  width: 100%;
  margin-top: 24rpx;
}

.result-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.result-item {
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #f8fcf5;
  border: 2rpx solid #dcefd0;
}

.result-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.result-value {
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.success-text {
  color: var(--brand-green-dark);
}

.info-text {
  color: var(--brand-blue-dark);
}

.error-panel {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fff7f7;
  border: 2rpx solid rgba(255, 75, 75, 0.2);
}

.error-title {
  font-size: 26rpx;
  font-weight: 800;
  color: var(--danger-dark);
}

.error-row {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8d3b3b;
}
