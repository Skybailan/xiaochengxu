.home-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 40rpx;
  padding-top: 64rpx;
}

.hero-block {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 10rpx 8rpx;
}

.hero-badge {
  align-self: flex-start;
}

.hero-title {
  font-size: 56rpx;
  line-height: 1.22;
  font-weight: 800;
  color: var(--text-primary);
}

.hero-subtitle {
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.mode-grid {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.mode-card {
  position: relative;
  overflow: hidden;
  padding: 34rpx 30rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.mode-card::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -40rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(88, 204, 2, 0.18), rgba(88, 204, 2, 0));
}

.import-card::before {
  background: radial-gradient(circle, rgba(28, 140, 255, 0.18), rgba(28, 140, 255, 0));
}

.mode-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 58rpx;
  background: linear-gradient(180deg, #f3ffe7 0%, #e6f8d7 100%);
  box-shadow: inset 0 0 0 2rpx rgba(88, 204, 2, 0.12);
}

.mode-icon-blue {
  background: linear-gradient(180deg, #ecf6ff 0%, #dcebff 100%);
  box-shadow: inset 0 0 0 2rpx rgba(28, 140, 255, 0.14);
}

.mode-badge {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(28, 140, 255, 0.1);
  color: var(--brand-blue-dark);
  font-size: 22rpx;
  font-weight: 700;
}

.mode-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.mode-subtitle {
  font-size: 27rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.mode-footer {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: var(--brand-green-dark);
  font-size: 28rpx;
  font-weight: 700;
}

.import-card .mode-footer {
  color: var(--brand-blue-dark);
}

.mode-arrow {
  font-size: 34rpx;
}
